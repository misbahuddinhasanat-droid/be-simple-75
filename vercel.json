{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/products/:id", "destination": "/api/products?id=:id" },
    { "source": "/api/orders/:id", "destination": "/api/orders?id=:id" },
    { "source": "/api/cart/items/:itemId", "destination": "/api/cart?itemId=:itemId" },
    { "source": "/api/admin/leads/:id", "destination": "/api/admin/leads?id=:id" },
    { "source": "/api/admin/orders/:id", "destination": "/api/admin/orders?id=:id" },
    { "source": "/api/admin/products/:id", "destination": "/api/admin/products?id=:id" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
